# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# --- Secrets (required) ----------------------------------------------------
# JSearch API key from https://app.openwebninja.com
JSEARCH_API_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your chat id. Easiest way: message your bot, then open
# https://api.telegram.org/bot<TOKEN>/getUpdates and read result[].message.chat.id
TELEGRAM_CHAT_ID=

# --- Search (optional, sensible defaults shown) ----------------------------
# Always include a location term (even "remote") in the query.
JOB_QUERY=devops engineer remote

# Comma-separated. A job is kept if its title or description contains any of these.
KEYWORDS=devops,platform engineer,kubernetes,site reliability,react native,expo

# Multiple queries per cycle (optional). Set JOB_QUERY_1/KEYWORDS_1,
# JOB_QUERY_2/KEYWORDS_2, … (numbered from 1, contiguous — the scan stops at the
# first missing JOB_QUERY_n). Each query has its OWN keyword filter and is
# REQUIRED to set its KEYWORDS_n. When any JOB_QUERY_1 is present the numbered
# set fully replaces the single JOB_QUERY/KEYWORDS above. The shared knobs below
# (DATE_POSTED, REMOTE_ONLY, country/language, MAX_PAGES) apply to every query.
# NOTE: each query is a separate API call per cycle, so N queries use ~N× the
# requests — the MONTHLY_REQUEST_BUDGET guard below is what keeps that safe.
# JOB_QUERY_1=devops engineer remote
# KEYWORDS_1=devops,platform engineer,kubernetes,site reliability
# JOB_QUERY_2=react native developer remote
# KEYWORDS_2=react native,expo

# Freshness filter sent to JSearch: all | today | 3days | week | month
DATE_POSTED=today

# Remote-only results (maps to work_from_home=true)
REMOTE_ONLY=true

# Non-US targeting (optional), e.g. JOB_COUNTRY=fr JOB_LANGUAGE=fr
JOB_COUNTRY=
JOB_LANGUAGE=

# --- Scheduling ------------------------------------------------------------
# Go duration. 5h ≈ 150 requests/month — safely inside the JSearch free tier
# (200/mo). Going hourly (~720/mo) needs the Pro plan.
POLL_INTERVAL=5h

# Set to true to run a single cycle and exit (useful for testing / cron).
RUN_ONCE=false

# Pages to fetch per cycle by following the JSearch cursor. 1 = first page only.
# WARNING: each extra page is one more request/cycle. At POLL_INTERVAL=5h (~144
# cycles/mo) even MAX_PAGES=2 (~288/mo) blows the 200/mo free tier — raise this
# only on the Pro plan or with a longer interval. The Quota guard on the roadmap
# is what would make higher values safe automatically.
MAX_PAGES=1

# Max JSearch requests per calendar month before the service pauses API calls
# (and pushes one warning). 200 = the free tier. 0 disables the guard (e.g. on a
# paid plan). The counter is persisted in SQLite, so it survives restarts.
MONTHLY_REQUEST_BUDGET=200

# --- Storage ---------------------------------------------------------------
DB_PATH=data/jobs.db

# --- Ops -------------------------------------------------------------------
# Listen address for the /healthz liveness endpoint (e.g. :8080). Empty disables
# it. Liveness only reflects that the poll loop is still turning — it stays green
# during a JSearch outage or quota pause (a restart wouldn't fix those). The
# Docker image sets this to :8080 and self-probes via `jobalert -healthcheck`.
HEALTH_ADDR=
